{
  "name": "codex-browser-use-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions/browser-use.ts"
    ],
    "skills": [
      "."
    ]
  },
  "scripts": {
    "bridge": "node scripts/bridge.mjs",
    "check": "tsc --noEmit && node --check scripts/bridge.mjs && node --check extension/background.js && node --check extension/options.js",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.6",
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.20.0"
}
