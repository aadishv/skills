{
  "manifest_version": 3,
  "name": "Codex Browser Use Bridge",
  "description": "Exposes Chrome DevTools Protocol sessions to the local codex-browser-use skill.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "alarms",
    "debugger",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Codex Browser Use Bridge"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src ws://127.0.0.1:* ws://localhost:*"
  }
}
